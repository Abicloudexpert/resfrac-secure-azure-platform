# ---------------------------------------------------------------------------
# Local development configuration TEMPLATE. Copy to `.env` (git-ignored).
# NO REAL SECRETS BELONG IN THIS FILE. In Azure, all of these are injected by
# the platform (App Settings) or resolved via Managed Identity / Key Vault.
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=8080
SERVICE_NAME=resfrac-api
LOG_LEVEL=info

# ---- Microsoft Entra ID (OAuth2/JWT) ----
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
API_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Optional explicit overrides (otherwise derived from the two values above):
# AUTH_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# AUTH_JWKS_URI=https://login.microsoftonline.com/<tenant>/discovery/v2.0/keys
# AUTH_AUDIENCE=api://<api-client-id>
AUTH_REQUIRED_SCOPE=Data.Read
# Set to false ONLY for isolated local smoke tests. Never in a deployed env.
AUTH_ENABLED=true

# ---- Azure SQL (Managed Identity / passwordless) ----
SQL_ENABLED=true
SQL_SERVER=sql-resfrac-dev.database.windows.net
SQL_DATABASE=sqldb-resfrac-dev

# ---- Key Vault (Managed Identity) ----
KEYVAULT_ENABLED=true
KEYVAULT_URI=https://kv-resfrac-dev.vault.azure.net
KEYVAULT_DEMO_SECRET=api-feature-flag

# ---- Application Insights ----
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ---- HTTP hardening ----
CORS_ORIGINS=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
